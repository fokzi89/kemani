# Supabase Configuration
# Get these values from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# SMS Provider (Termii) - Get from https://termii.com
TERMII_API_KEY=
TERMII_SENDER_ID=Kemani

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# Security
JWT_SECRET=your-random-secret-key-change-this
RATE_LIMIT_MAX_REQUESTS=3
RATE_LIMIT_WINDOW_MS=3600000

# Optional: PowerSync Configuration (for offline sync)
# POWERSYNC_URL=

# Resend Email Configuration (for staff invitations)
# Get from: https://resend.com/api-keys
RESEND_API_KEY=
FROM_EMAIL=noreply@yourdomain.com

# Geocoding API Keys (for address to lat/long conversion during onboarding)
# Choose at least one provider. If none configured, system uses free Nominatim (OpenStreetMap)

# Google Maps Geocoding API (Recommended - Most accurate, $5/1000 requests)
# Get from: https://console.cloud.google.com/apis/credentials
# Enable "Geocoding API" in your Google Cloud project
# GOOGLE_MAPS_API_KEY=

# OpenCage Geocoding API (Alternative - 2500 free requests/day, then $0.001/request)
# Get from: https://opencagedata.com/api
# OPENCAGE_API_KEY=

# Google OAuth (for "Sign in with Google" feature)
# Get from: https://console.cloud.google.com/apis/credentials
# Create OAuth 2.0 Client ID for Web application
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
