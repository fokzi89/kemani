# ============================================================
# Supabase Configuration
# ============================================================
# Get these values from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ============================================================
# SMS Provider (Termii) - Optional
# ============================================================
# Get from https://termii.com
# Used for OTP and SMS notifications

TERMII_API_KEY=
TERMII_SENDER_ID=Kemani

# ============================================================
# App Configuration
# ============================================================

NODE_ENV=development

# ============================================================
# Security
# ============================================================

JWT_SECRET=your-random-secret-key-change-this-to-something-secure
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MS=3600000

# ============================================================
# Optional: PowerSync Configuration (for offline sync)
# ============================================================
# POWERSYNC_URL=
# POWERSYNC_KEY=

# ============================================================
# Optional: Analytics & Monitoring
# ============================================================
# SENTRY_DSN=
# GOOGLE_ANALYTICS_ID=

# ============================================================
# Notes
# ============================================================
# Each app (SvelteKit/Flutter) has its own environment configuration:
# - SvelteKit apps: apps/*/. env (use PUBLIC_ prefix for client-side vars)
# - Flutter apps: Use --dart-define or lib/config/ files
#
# See individual app READMEs for specific environment setup instructions.
