# Supabase Configuration (REQUIRED)
# Get these from: https://supabase.com/dashboard → Your Project → Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Paystack Configuration (REQUIRED for payments)
# Get test keys from: https://dashboard.paystack.com/#/settings/developer
PAYSTACK_SECRET_KEY=sk_test_your_paystack_secret_key
PAYSTACK_PUBLIC_KEY=pk_test_your_paystack_public_key
PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_your_paystack_public_key

# App Configuration
PUBLIC_APP_NAME=Kemani Storefront
PUBLIC_APP_URL=http://localhost:5173

# Note:
# - Use test keys (sk_test_...) for development
# - Switch to live keys (sk_live_...) for production
# - Never commit .env file to git
