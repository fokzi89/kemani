# Supabase Configuration
# Get these values from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_ANON_KEY=

# Paystack Configuration
# Get from: https://dashboard.paystack.com/#/settings/developer
PUBLIC_PAYSTACK_PUBLIC_KEY=
PAYSTACK_SECRET_KEY=

# App Configuration
PUBLIC_APP_URL=http://localhost:5173
PUBLIC_API_URL=http://localhost:3000/api

# OAuth Configuration
# Google OAuth (for "Sign in with Google")
# Get from: https://console.cloud.google.com/apis/credentials
PUBLIC_GOOGLE_CLIENT_ID=

# Apple OAuth (for "Sign in with Apple")
# Get from: https://developer.apple.com/account/resources/identifiers/list
PUBLIC_APPLE_CLIENT_ID=

# Chat Configuration
# WebSocket/Realtime URL (usually same as Supabase URL)
PUBLIC_REALTIME_URL=

# Feature Flags
PUBLIC_ENABLE_AI_CHAT=false
PUBLIC_ENABLE_MULTI_BRANCH=false
